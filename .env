# ── PostgreSQL ──
POSTGRES_DB=midnight_drop
POSTGRES_USER=midnight
POSTGRES_PASSWORD=midnight_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Stripe (test mode — leave blank for mock fallback) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── JWT ──
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=120

# ── Sale Config ──
RESERVATION_TTL_SECONDS=120
SWEEPER_INTERVAL_SECONDS=30
# Demo: batch_size=100 for fast bot throughput. Production: 50+
WAITING_ROOM_BATCH_SIZE=100

# ── Rate Limits (demo-friendly — increase for simulation) ──
RATE_LIMIT_WAITING_ROOM=100/minute
RATE_LIMIT_RESERVE=100/minute
RATE_LIMIT_PAYMENT=100/minute

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
