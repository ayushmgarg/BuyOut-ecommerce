# ── PostgreSQL ──
POSTGRES_DB=midnight_drop
POSTGRES_USER=midnight
POSTGRES_PASSWORD=midnight_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Stripe (test mode — leave blank for mock fallback) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── JWT ──
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=120

# ── Sale Config ──
RESERVATION_TTL_SECONDS=120
SWEEPER_INTERVAL_SECONDS=30
WAITING_ROOM_BATCH_SIZE=50

# ── Rate Limits ──
RATE_LIMIT_WAITING_ROOM=10/minute
RATE_LIMIT_RESERVE=1/minute
RATE_LIMIT_PAYMENT=3/minute

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
